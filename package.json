{
  "name": "tokentracker",
  "version": "1.0.0",
  "main": "index.ts",
  "private": false,
  "license": "MIT",
  "description": "Local-first, privacy-first LLM API usage tracker for OpenAI, Anthropic, xAI/Grok, and more.",
  "repository": {
    "type": "git",
    "url": "https://github.com/jdodsoncollins/TokenTracker.git"
  },
  "bugs": {
    "url": "https://github.com/jdodsoncollins/TokenTracker/issues"
  },
  "homepage": "https://github.com/jdodsoncollins/TokenTracker#readme",
  "keywords": [
    "llm",
    "openai",
    "anthropic",
    "xai",
    "grok",
    "token-tracker",
    "usage-tracker",
    "privacy",
    "react-native",
    "expo",
    "local-first"
  ],
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "smoke": "node scripts/manual-smoke.mjs",
    "doctor": "npx expo-doctor"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.36",
    "expo-blur": "~15.0.8",
    "expo-crypto": "~15.0.9",
    "expo-linear-gradient": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "@types/react-test-renderer": "^19.1.0",
    "@vitest/coverage-v8": "^3.2.7",
    "expo-doctor": "^1.20.1",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "postcss": "^8.5.12",
    "uuid": "^11.1.1"
  }
}
